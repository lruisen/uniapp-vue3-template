{
  "name": "uniapp-vue3-template",
  "version": "1.0.0",
  "description": "uniapp + vue3 + ts 项目初始化模板",
  "author": {
    "name": "Lruisen",
    "email": "lruisen@email.cn",
    "github": "https://github.com/lruisen"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9.0"
  },
  "scripts": {
    "dev:app": "pnpm build:config && uni -p app",
    "dev:app-android": "pnpm build:config && uni -p app-android",
    "dev:app-ios": "pnpm build:config && uni -p app-ios",
    "dev:app-harmony": "pnpm build:config && uni -p app-harmony",
    "dev:custom": "pnpm build:config && uni -p",
    "dev:h5": "uni",
    "dev:h5:ssr": "uni --ssr",
    "dev:mp-alipay": "pnpm build:config && uni -p mp-alipay",
    "dev:mp-baidu": "pnpm build:config && uni -p mp-baidu",
    "dev:mp-jd": "pnpm build:config && uni -p mp-jd",
    "dev:mp-kuaishou": "pnpm build:config && uni -p mp-kuaishou",
    "dev:mp-lark": "pnpm build:config && uni -p mp-lark",
    "dev:mp-qq": "pnpm build:config && uni -p mp-qq",
    "dev:mp-toutiao": "pnpm build:config && uni -p mp-toutiao",
    "dev:mp-weixin": "pnpm build:config && uni -p mp-weixin",
    "dev:mp-xhs": "pnpm build:config && uni -p mp-xhs",
    "dev:quickapp-webview": "pnpm build:config && uni -p quickapp-webview",
    "dev:quickapp-webview-huawei": "pnpm build:config && uni -p quickapp-webview-huawei",
    "dev:quickapp-webview-union": "pnpm build:config && uni -p quickapp-webview-union",
    "build:app": "pnpm build:config && uni build -p app",
    "build:app-android": "pnpm build:config && uni build -p app-android",
    "build:app-ios": "pnpm build:config && uni build -p app-ios",
    "build:app-harmony": "pnpm build:config && uni build -p app-harmony",
    "build:custom": "pnpm build:config && uni build -p",
    "build:h5": "uni build && pnpm build:h5_config",
    "build:h5:ssr": "uni build --ssr",
    "build:mp-alipay": "pnpm build:config && uni build -p mp-alipay",
    "build:mp-baidu": "pnpm build:config && uni build -p mp-baidu",
    "build:mp-jd": "pnpm build:config && uni build -p mp-jd",
    "build:mp-kuaishou": "pnpm build:config && uni build -p mp-kuaishou",
    "build:mp-lark": "pnpm build:config && uni build -p mp-lark",
    "build:mp-qq": "pnpm build:config && uni build -p mp-qq",
    "build:mp-toutiao": "pnpm build:config && uni build -p mp-toutiao",
    "build:mp-weixin": "pnpm build:config && uni build -p mp-weixin",
    "build:mp-xhs": "uni build -p mp-xhs",
    "build:quickapp-webview": "pnpm build:config && uni build -p quickapp-webview",
    "build:quickapp-webview-huawei": "pnpm build:config && uni build -p quickapp-webview-huawei",
    "build:quickapp-webview-union": "pnpm build:config && uni build -p quickapp-webview-union",
    "type-check": "vue-tsc --noEmit",
    "build:config": "esno ./scripts/setConfigFile.ts",
    "build:h5_config": "esno ./scripts/setConfigFile.ts --output=h5",
    "prettier:src": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,less}\""
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4020920240930001",
    "@dcloudio/uni-app-harmony": "3.0.0-4020920240930001",
    "@dcloudio/uni-app-plus": "3.0.0-4020920240930001",
    "@dcloudio/uni-components": "3.0.0-4020920240930001",
    "@dcloudio/uni-h5": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-baidu": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-jd": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-lark": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-qq": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-xhs": "3.0.0-4020920240930001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-4020920240930001",
    "luch-request": "^3.1.1",
    "pinia": "^2.2.4",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "^3.4.21",
    "vue-i18n": "^9.1.9"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.12",
    "@dcloudio/uni-automator": "3.0.0-4020920240930001",
    "@dcloudio/uni-cli-shared": "3.0.0-4020920240930001",
    "@dcloudio/uni-stacktracey": "3.0.0-4020920240930001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4020920240930001",
    "@types/fs-extra": "^11.0.4",
    "@uni-helper/vite-plugin-uni-manifest": "^0.2.7",
    "@vue/runtime-core": "^3.4.21",
    "@vue/tsconfig": "^0.5.1",
    "dotenv": "^10.0.0",
    "esno": "^4.8.0",
    "fs-extra": "^11.2.0",
    "postcss": "^8.4.47",
    "postcss-html": "^1.7.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.3.3",
    "sass": "^1.79.5",
    "sass-loader": "^16.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "unocss": "0.58",
    "unocss-preset-weapp": "0.58",
    "unplugin-auto-import": "^0.18.3",
    "vite": "5.2.8",
    "vite-plugin-html": "^3.2.2",
    "vue-tsc": "^2.1.6"
  }
}
